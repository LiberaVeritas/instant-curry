PRINT 5.


THEOREM (map_id).
FORALL (l : 'a list) : map id l = l : 'a list. 

PROOF. 
BY INDUCTION ON l.

CASE l = [].
WTS: map id [] = [].
LHS = map id [].
    = []                            -- BY defn.

RHS = [].

CASE l = y :: ys.
# infer ih test
# IH: map id ys = ys.
# WTS: map id (y :: ys) = y :: ys.    # optional

LHS = map id (y :: ys).
    = id y :: map id ys             -- BY defn.
    = y :: map id ys                -- BY defn.
    = y :: ys                       -- BY IH.

RHS = y :: ys.

QED.


THEOREM (map_fusion). 
FORALL (f : 'b -> 'c) (g : 'a -> 'b) (l : 'a list) :
    map (fun (x : 'a) => f (g x) end) l = map f (map g l) : 'c list.

PROOF. BY INDUCTION ON l.

CASE l = [].
# WTS: map (fun (x : 'a) => f (g x) end) [] = map f (map g []).

LHS = map (fun (x : 'a) => f (g x) end) [].
    = []                        -- BY defn.

RHS = map f (map g []).
    = map f []                  -- BY defn.
    = []                        -- BY defn.

CASE l = x :: xs.
IH: map (fun (x : 'a) => f (g x) end) xs = map f (map g xs).
WTS: map (fun (x : 'a) => f (g x) end) (x :: xs) = map f (map g (x :: xs)).

LHS = map (fun (x : 'a) => f (g x) end) (x :: xs).
    = (fun (x : 'a) => f (g x) end) x :: 
  map (fun (x : 'a) => f (g x) end) xs   -- BY defn.
      
    = f (g x) :: map (fun (x : 'a) => f (g x) end) xs    -- BY eval.
    = f (g x) :: map f (map g xs)   -- BY IH.

RHS = map f (map g (x :: xs)).
    = map f (g x :: map g xs)                   -- BY defn.
    = f (g x) :: map f (map g xs)               -- BY defn.

QED.

