Require Import stdlib.
Fixpoint map {B A : Set} (f : ((A) -> (B))) (l : (list (A))) : (list (B)) := (match (l) with | Nil => (Nil) | Cons x xs => (Cons ((f) (x)) (((map) (f)) (xs))) end).
Fixpoint len {A : Set} (l : (list (A))) : (nat) := (match (l) with | Nil => (0) | Cons x xs => (plus (1) ((len) (xs))) end).
Definition id {A : Set} (x : (A)) : (A) := (x).
Theorem map_id {A : Set} (l : (list (A))) : ((((map) (id)) (l)) = (l)).
Proof. 
induction l as [| x xs IH1 ]; intros.
- apply lhs_is_rhs with (C := (Nil)).
-- next_refl ((Nil) : (list (A))).
reflexivity. 
-- reflexivity. 

- rename x into y.
rename xs into ys.
apply lhs_is_rhs with (C := (Cons (y) (ys))).
-- next_refl ((Cons ((id) (y)) (((map) (id)) (ys))) : (list (A))).
next_refl ((Cons (y) (((map) (id)) (ys))) : (list (A))).
next_hyp ((Cons (y) (ys)) : (list (A))) IH1.
reflexivity. 
-- reflexivity. 

Qed.
Theorem map_len {B A : Set} (l : (list (A))) (f : ((A) -> (B))) : (((len) (((map) (f)) (l))) = ((len) (l))).
Proof. 
induction l as [| x xs IH1 ]; intros.
- apply lhs_is_rhs with (C := ((len) (Nil))).
-- next_refl (((len) (Nil)) : (nat)).
reflexivity. 
-- reflexivity. 

- rename x into x.
rename xs into xs.
apply lhs_is_rhs with (C := (plus ((len) (xs)) (1))).
-- next_refl (((len) (Cons ((f) (x)) (((map) (f)) (xs)))) : (nat)).
next_refl ((plus ((len) (((map) (f)) (xs))) (1)) : (nat)).
next_hyp ((plus ((len) (xs)) (1)) : (nat)) IH1.
reflexivity. 
-- next_refl ((plus ((len) (xs)) (1)) : (nat)).
reflexivity. 

Qed.
