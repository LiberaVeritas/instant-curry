THEOREM (eq).
FORALL (l : nat list) : l = l.
    PROOF BY INDUCTION ON l.

    CASE l = [].
        WTS: l = l.
        
        LHS = [] nat.
        RHS = [] nat.

    CASE l = x :: xs.
        IH: xs = xs.
        WTS: x :: xs = x :: xs.

        LHS = x :: xs.
        RHS = x :: xs.
QED.