THEOREM (app_nil).
FORALL (l : 'a lisr) : app l [] = l : 'a list.

PROOF.
BY INDUCTION ON l.

CASE l = [].
WTS: app [] [] = [].

LHS = app [] [].
    = [] -- BY defn.

RHS = [].

CASE l = x :: xs.
IH1: app xs [] = xs.
WTS: app (x :: xs) [] = x :: xs.

LHS = app (x :: xs) [].
    = x :: (app xs []) -- BY defn.
    = x :: xs -- BY IH1.

RHS = x :: xs.

QED.


THEOREM (assoc).
FORALL (l1 : 'a list) (l2 : 'a list) (l3 : 'a list) : app (app l1 l2) l3 = app l1 (app l2 l3) : 'a list.

PROOF.
BY INDUCTION ON l1.

CASE l1 = []
WTS: app (app [] l2) l3 = app [] (app l2 l3).

LHS = app (app [] l2) l3.
    = app l2 l3 -- BY defn.

RHS = app [] (app l2 l3).
    = app l2 l3 -- BY defn.

CASE l1 = x :: xs.
IH1: app (app xs l2) l3 = app xs (app l2 l3).
WTS: app (app (x :: xs) l2) l3 = app (x :: xs) (app l2 l3).

LHS = app (app (x :: xs) l2) l3.
    = app (x :: (app xs l2)) l3 -- BY defn.
    = x :: (app (app xs l2) l3) -- BY defn.
    = x :: (app xs (app l2 l3)) -- BY IH1.

RHS = app (x :: xs) (app l2 l3).
    = x :: (app xs (app l2 l3)) -- BY defn.

QED.


THEOREM (map_eq).
FORALL (f : 'a -> 'b) (l : 'a list) (acc : 'b list) : app (rev (map f l)) acc = map_tr f l acc : 'b list.

PROOF.
BY INDUCTION ON l.

CASE l = [].
WTS: app (rev (map f [])) acc = map_tr f [] acc.

LHS = app (rev (map f [])) acc.
    = app (rev []) acc -- BY defn.
    = app [] acc -- BY defn.
    = acc -- BY defn.

RHS = map_tr f [] acc.
    = acc -- BY defn.

CASE l = x :: xs.
IH1: app (rev (map f xs)) acc = map_tr f xs acc.
WTS: app (rev (map f (x :: xs))) acc = map_tr f (x :: xs) acc.

LHS = app (rev (map f (x :: xs))) acc.
    = app (rev ((f x) :: (map f xs))) acc -- BY defn.
    = app (app (rev (map f xs)) ((f x) :: [])) acc -- BY defn.
    = app (rev (map f xs)) (app ((f x) :: []) acc) -- BY LEMMA assoc.
    = map_tr f xs (app ((f x) :: []) acc) -- BY IH1.

RHS = map_tr f (x :: xs) acc.
    = map_tr f xs (app ((f x) :: []) acc) -- BY defn.

QED.
    