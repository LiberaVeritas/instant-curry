THEOREM (rev_filter).
FORALL (l : 'a list) (f : 'a -> nat)  : 
rev (filter f l) = filter f (rev l) : 'a list.

PROOF.
BY INDUCTION ON l.

CASE l = [].
WTS: rev (filter f []) = filter f (rev []).

LHS = rev (filter f []).
    = rev [] -- BY defn.
    = [] -- BY defn.

RHS = filter f (rev []).
    = filter f [] -- BY defn.
    = [] -- BY defn.

CASE l = x :: xs.
IH: rev (filter f xs) = filter f (rev xs).
WTS: rev (filter f (x :: xs)) = filter f (rev (x :: xs)).

LHS = rev (filter f (x :: xs)).
    = rev (if0 (f x) then (x :: filter f xs) else (filter f xs) end) -- BY defn.
    = rev (if0 1 then (x :: filter f xs) else (filter f xs) end) -- BY defn.
    = rev (x :: filter f xs) -- BY eval.
    = app (rev (filter f xs)) (x :: []) -- BY defn.
    = app (filter f (rev xs)) (x :: []) -- BY IH.

RHS = filter f (rev (x :: xs)).
    = filter f (app (rev xs) (x :: [])) -- BY defn.
    = app (filter f (rev xs) (x :: [])) -- BY app_assoc.
    
QED.
